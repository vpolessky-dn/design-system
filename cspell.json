{
	"$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
	"enableGlobDot": true,
	"useGitignore": true,
	"import": ["@cspell/dict-cspell-bundle/cspell-ext.json", "@cspell/dict-mime-types/cspell-ext.json"],
	"dictionaries": ["typescript", "npm", "filetypes", "softwareTerms", "mime-types", "local-words"],
	"dictionaryDefinitions": [
		{
			"name": "local-words",
			"path": "./cspell/local-words.txt",
			"description": "Local words for the project"
		}
	],
	"ignorePaths": [".cursor", ".git", ".github", ".vscode/extensions.json", ".cspell", "pnpm-lock.yaml"]
}
