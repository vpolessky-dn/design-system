{
	"$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
	"enableGlobDot": true,
	"useGitignore": true,
	"import": ["@cspell/dict-cspell-bundle/cspell-ext.json", "@cspell/dict-mime-types/cspell-ext.json"],
	"dictionaries": ["typescript", "npm", "filetypes", "softwareTerms", "mime-types"],
	"words": [
		"autoboot",
		"autodocs",
		"borderless",
		"clickability",
		"controlify",
		"drivenets",
		"evenodd",
		"findlast",
		"fromentries",
		"gnmi",
		"matchall",
		"netural",
		"netgen",
		"ondark",
		"noninteractive",
		"onwarn",
		"reorderable",
		"retryable",
		"subcomponents",
		"tosorted",
		"TSESTree",
		"unhover"
	],
	"ignorePaths": [".cursor", ".git", ".github", ".vscode", ".cspell", "pnpm-lock.yaml"]
}
