{
	"$schema": "https://turborepo.com/schema.json",
	"extends": ["//"],
	"tasks": {
		"test": {
			"dependsOn": ["$TURBO_EXTENDS$", "install:playwright"]
		},
		"test:coverage": {
			"dependsOn": ["$TURBO_EXTENDS$", "install:playwright"]
		},
		"install:playwright": {
			"dependsOn": []
		},
		"build:storybook": {
			"outputs": ["storybook-static/**"],
			"inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/packages/vite-plugin/**"]
		}
	}
}
