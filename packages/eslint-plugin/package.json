{
	"name": "@drivenets/eslint-plugin-design-system",
	"version": "0.0.11",
	"license": "Apache-2.0",
	"type": "module",
	"types": "./dist/index.d.cts",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"README.md",
		"CHANGELOG.md",
		"LICENSE",
		"./dist",
		"./src",
		"!**/__tests__"
	],
	"repository": {
		"url": "https://github.com/drivenets/design-system",
		"directory": "/packages/eslint-plugin"
	},
	"scripts": {
		"lint": "eslint --max-warnings=0 .",
		"typecheck": "tsc",
		"test": "vitest",
		"test:coverage": "pnpm test --coverage",
		"build": "tsdown",
		"build:lint": "publint && attw --pack"
	},
	"dependencies": {
		"@eslint/core": "^1.1.1",
		"eslint-no-restricted": "^0.1.1"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@vitest/coverage-v8": "^4.1.0",
		"eslint": "^10.0.1",
		"publint": "^0.3.18",
		"tsdown": "^0.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"peerDependencies": {
		"@typescript-eslint/parser": "^8.50.0",
		"eslint": "^9.0.0 || ^10.0.0",
		"typescript": "^5.0.0"
	}
}
