{
	"name": "@drivenets/vite-plugin-design-system",
	"version": "0.0.8",
	"license": "Apache-2.0",
	"type": "module",
	"types": "./src/index.ts",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"require": "./src/index.ts"
		}
	},
	"publishConfig": {
		"types": "./dist/index.d.cts",
		"main": "./dist/index.cjs",
		"module": "./dist/index.js",
		"exports": {
			".": {
				"import": "./dist/index.js",
				"require": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"README.md",
		"CHANGELOG.md",
		"LICENSE",
		"./dist",
		"./src"
	],
	"repository": {
		"url": "https://github.com/drivenets/design-system",
		"directory": "/packages/vite-plugin"
	},
	"scripts": {
		"lint": "eslint --max-warnings=0 .",
		"lint:build": "TARBALL=$(pnpm pack | tail -n1) && publint $TARBALL && attw $TARBALL; rm -f $TARBALL",
		"typecheck": "tsgo",
		"build": "tsdown",
		"test": "vitest",
		"test:coverage": "pnpm test --coverage"
	},
	"peerDependencies": {
		"vite": "*"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "catalog:",
		"@typescript/native-preview": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"eslint": "catalog:",
		"publint": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
